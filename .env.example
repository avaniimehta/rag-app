# Copy this file to .env and adjust as needed. No secrets required -
# Ollama runs locally and free, so there's no API key here.

CHUNK_SIZE=500
CHUNK_OVERLAP=50

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384

INDEX_DIR=data/index
DEFAULT_TOP_K=5
MIN_SIMILARITY=0.3

LLM_PROVIDER=ollama
LLM_MODEL=mistral
OLLAMA_HOST=http://localhost:11434

CORPUS_DIR=data/corpus
